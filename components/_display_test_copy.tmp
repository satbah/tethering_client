// display_test.c — LCD test-pattern suite + drawing primitives for the
// JC4827W543C (NV3041A over QSPI).
//
// Colors are RGB565 as produced by RGB565(). The NV3041A panel driver is
// configured with color-inversion and byte-swap ON, so we DO NOT swap here.
#include <string.h>

#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "esp_log.h"
#include "esp_heap_caps.h"
#include "esp_timer.h"

#include "font8x8.h"
#include "display_test.h"
#include "board_config.h"

static const char *TAG = "disp_test";

static esp_lcd_panel_handle_t s_panel = NULL;

// Contiguous scratch buffer, big enough for any region we draw at once
// (a full screen). draw_bitmap() requires the region to be contiguous with
// stride == region width, so we always render into this buffer first.
#define SCRATCH_PIXELS (LCD_H_RES * LCD_V_RES)
static uint16_t *s_scratch = NULL;

// ---------------------------------------------------------------------------
// Init
// ---------------------------------------------------------------------------
void display_test_init(esp_lcd_panel_handle_t panel)
{
    s_panel = panel;

    if (s_scratch == NULL) {
        s_scratch = heap_caps_malloc(SCRATCH_PIXELS * sizeof(uint16_t),
                                     MALLOC_CAP_SPIRAM);
        if (s_scratch == NULL) {
            ESP_LOGW(TAG, "PSRAM scratch alloc failed, trying internal RAM");
            s_scratch = heap_caps_malloc(SCRATCH_PIXELS * sizeof(uint16_t),
                                         MALLOC_CAP_8BIT);
        }
        if (s_scratch == NULL) {
            ESP_LOGE(TAG, "scratch buffer alloc FAILED (%d bytes)",
                     (int)(SCRATCH_PIXELS * sizeof(uint16_t)));
        } else {
            ESP_LOGI(TAG, "scratch buffer %d bytes @ %p",
                     (int)(SCRATCH_PIXELS * sizeof(uint16_t)), s_scratch);
        }
    }
}

// ---------------------------------------------------------------------------
// Primitives
// ---------------------------------------------------------------------------
void display_fill_rect(int x, int y, int w, int h, uint16_t color565)
{
    if (s_panel == NULL || s_scratch == NULL) {
        return;
    }

    // Clip to the panel.
    if (x < 0) { w += x; x = 0; }
    if (y < 0) { h += y; y = 0; }
    if (x >= LCD_H_RES || y >= LCD_V_RES) {
        return;
    }
    if (x + w > LCD_H_RES) { w = LCD_H_RES - x; }
    if (y + h > LCD_V_RES) { h = LCD_V_RES - y; }
    if (w <= 0 || h <= 0) {
        return;
    }

    int count = w * h;
    for (int i = 0; i < count; i++) {
        s_scratch[i] = color565;
    }
    esp_lcd_panel_draw_bitmap(s_panel, x, y, x + w, y + h, s_scratch);
}

void display_fill_screen(uint16_t color565)
{
    display_fill_rect(0, 0, LCD_H_RES, LCD_V_RES, color565);
}

void display_draw_text(int x, int y, const char *s, uint16_t fg, uint16_t bg,
                       int scale)
{
    if (s_panel == NULL || s_scratch == NULL || s == NULL || scale < 1) {
        return;
    }

    const int gw = 8 * scale;   // glyph width  in pixels
    const int gh = 8 * scale;   // glyph height in pixels
    int cx = x;

    for (; *s; s++) {
        unsigned char ch = (unsigned char)*s;
        if (ch >= 128) {
            ch = '?';
        }

        // Only render glyphs that fit fully on-screen (keeps the scratch
        // stride == glyph width and avoids draw_bitmap out-of-range calls).
        if (cx >= 0 && cx + gw <= LCD_H_RES && y >= 0 && y + gh <= LCD_V_RES) {
            for (int row = 0; row < 8; row++) {
                uint8_t bits = font8x8_basic[ch][row];
                for (int sy = 0; sy < scale; sy++) {
                    int base = (row * scale + sy) * gw;
                    for (int col = 0; col < 8; col++) {
                        uint16_t color = (bits & (1u << col)) ? fg : bg;
                        int off = base + col * scale;
                        for (int sx = 0; sx < scale; sx++) {
                            s_scratch[off + sx] = color;
                        }
                    }
                }
            }
            esp_lcd_panel_draw_bitmap(s_panel, cx, y, cx + gw, y + gh, s_scratch);
        }
        cx += gw;
    }
}

// ---------------------------------------------------------------------------
// Patterns
// ---------------------------------------------------------------------------
void display_test_color_bars(void)
{
    static const uint16_t bars[8] = {
        COLOR_WHITE, COLOR_YELLOW, COLOR_CYAN, COLOR_GREEN,
        COLOR_MAGENTA, COLOR_RED, COLOR_BLUE, COLOR_BLACK,
    };
    int bw = LCD_H_RES / 8;
    for (int i = 0; i < 8; i++) {
        int x = i * bw;
        int w = (i == 7) ? (LCD_H_RES - x) : bw;   // absorb rounding remainder
        display_fill_rect(x, 0, w, LCD_V_RES, bars[i]);
    }
}

void display_test_solid_fills(void)
{
    static const uint16_t colors[5] = {
        COLOR_RED, COLOR_GREEN, COLOR_BLUE, COLOR_WHITE, COLOR_BLACK,
    };
    for (int i = 0; i < 5; i++) {
        display_fill_screen(colors[i]);
        vTaskDelay(pdMS_TO_TICKS(600));
    }
}

void display_test_gradient(void)
{
    if (s_panel == NULL || s_scratch == NULL) {
        return;
    }

    const int half = LCD_V_RES / 2;

    // Top half: horizontal gradient red -> blue.
    for (int row = 0; row < half; row++) {
        uint16_t *line = &s_scratch[row * LCD_H_RES];
        for (int x = 0; x < LCD_H_RES; x++) {
            int r = 255 - (255 * x) / (LCD_H_RES - 1);
            int b = (255 * x) / (LCD_H_RES - 1);
            line[x] = RGB565(r, 0, b);
        }
    }
    esp_lcd_panel_draw_bitmap(s_panel, 0, 0, LCD_H_RES, half, s_scratch);

    // Bottom half: vertical gradient black -> white.
    const int bh = LCD_V_RES - half;
    for (int row = 0; row < bh; row++) {
        int v = (255 * row) / (bh - 1);
        uint16_t g = RGB565(v, v, v);
        uint16_t *line = &s_scratch[row * LCD_H_RES];
        for (int x = 0; x < LCD_H_RES; x++) {
            line[x] = g;
        }
    }
    esp_lcd_panel_draw_bitmap(s_panel, 0, half, LCD_H_RES, LCD_V_RES, s_scratch);
}

void display_test_checkerboard(void)
{
    if (s_panel == NULL || s_scratch == NULL) {
        return;
    }

    const int sq = 16;
    for (int y = 0; y < LCD_V_RES; y++) {
        uint16_t *line = &s_scratch[y * LCD_H_RES];
        int yb = y / sq;
        for (int x = 0; x < LCD_H_RES; x++) {
            int on = ((x / sq) + yb) & 1;
            line[x] = on ? COLOR_WHITE : COLOR_BLACK;
        }
    }
    esp_lcd_panel_draw_bitmap(s_panel, 0, 0, LCD_H_RES, LCD_V_RES, s_scratch);
}

void display_test_fps_benchmark(int seconds)
{
    if (s_panel == NULL || s_scratch == NULL || seconds <= 0) {
        return;
    }

    const int box = 40;
    int x = 0, y = 0;
    int dx = 5, dy = 3;

    display_fill_screen(COLOR_BLACK);

    uint32_t frames = 0;
    int64_t t_start = esp_timer_get_time();
    int64_t t_end = t_start + (int64_t)seconds * 1000000;

    int px = x, py = y;
    while (esp_timer_get_time() < t_end) {
        // Erase previous box position.
        display_fill_rect(px, py, box, box, COLOR_BLACK);

        // Advance and bounce.
        x += dx;
        y += dy;
        if (x < 0)                 { x = 0;                 dx = -dx; }
        if (x + box > LCD_H_RES)   { x = LCD_H_RES - box;   dx = -dx; }
        if (y < 0)                 { y = 0;                 dy = -dy; }
        if (y + box > LCD_V_RES)   { y = LCD_V_RES - box;   dy = -dy; }

        display_fill_rect(x, y, box, box, COLOR_CYAN);

        px = x;
        py = y;
        frames++;
    }

    int64_t elapsed_us = esp_timer_get_time() - t_start;
    double secs = (double)elapsed_us / 1000000.0;
    double fps = (secs > 0.0) ? (double)frames / secs : 0.0;
    ESP_LOGI(TAG, "FPS benchmark: %lu frames in %.2f s = %.1f FPS",
             (unsigned long)frames, secs, fps);
}

// ---------------------------------------------------------------------------
// Full sequence
// ---------------------------------------------------------------------------
void display_test_run_all(void)
{
    ESP_LOGI(TAG, "=== display test: color bars ===");
    display_test_color_bars();
    display_draw_text(8, 8, "COLOR BARS", COLOR_BLACK, COLOR_WHITE, 2);
    vTaskDelay(pdMS_TO_TICKS(1500));

    ESP_LOGI(TAG, "=== display test: gradient ===");
    display_test_gradient();
    display_draw_text(8, 8, "GRADIENT", COLOR_WHITE, COLOR_BLACK, 2);
    vTaskDelay(pdMS_TO_TICKS(1500));

    ESP_LOGI(TAG, "=== display test: checkerboard ===");
    display_test_checkerboard();
    display_draw_text(8, 8, "CHECKER", COLOR_RED, COLOR_BLACK, 2);
    vTaskDelay(pdMS_TO_TICKS(1500));

    ESP_LOGI(TAG, "=== display test: solid fills ===");
    display_test_solid_fills();
    display_fill_screen(COLOR_BLACK);
    display_draw_text(8, 8, "SOLID FILLS", COLOR_WHITE, COLOR_BLACK, 2);
    vTaskDelay(pdMS_TO_TICKS(1000));

    ESP_LOGI(TAG, "=== display test: fps benchmark (5s) ===");
    display_test_fps_benchmark(5);

    ESP_LOGI(TAG, "=== display test: done ===");
}
